#!/usr/bin/env zsh
#
# z4m pack - Create an offline installation package
#
# Usage:
#   z4m pack [-o output] [-t tag]
#
# Creates a self-extracting script that can install z4m on machines
# without internet access.
#

emulate -L zsh -o typeset_silent -o pipe_fail -o extended_glob \
    -o prompt_percent -o no_prompt_subst -o no_prompt_bang -o no_bg_nice -o no_aliases
autoload -Uz -- -z4m-copy-path-with-excludes || return 1
autoload -Uz -- -z4m-pack-parse-copy-spec || return 1
-z4m-check-core-params || return

local output= tag=
local -a extra_files=()

zparseopts -D -F -- o:=output t:=tag || return '_z4m_err()'

output=${output[2]:-z4m-offline-install.sh}
tag=${tag[2]:-default}

local -r local_zdotdir=${ZDOTDIR:-$HOME}

# Get extra paths from zstyle
zstyle -a ":z4m:pack:$tag" extra-files extra_files || extra_files=()

print -Pr -- "%F{3}z4m%f: creating offline package: %F{2}${output//\%/%%}%f"

local tmpdir
if (( $+commands[mktemp] )); then
  tmpdir=$(command mktemp -d) || return
else
  tmpdir=/tmp/z4m-pack.$$
  zf_mkdir -p -- $tmpdir || return
fi

function -z4m-pack-stage-path() {
  emulate -L zsh -o typeset_silent -o pipe_fail -o extended_glob \
    -o prompt_percent -o no_prompt_subst -o no_prompt_bang -o no_bg_nice -o no_aliases

  local src=$1
  local root_kind=$2
  local rel=$3
  local payload_root=$4
  local manifest=$5
  local exclude_blob=${6-}

  [[ -e $src ]] || return 0
  [[ -n $rel && $rel != /* ]] || {
    print -Pru2 -- "%F{3}z4m%f: %Bpack%b: invalid relative path: %F{1}${rel//\%/%%}%f"
    return 1
  }
  [[ $rel != *$'\n'* && $rel != *$'\t'* ]] || {
    print -Pru2 -- "%F{3}z4m%f: %Bpack%b: unsupported path characters: %F{1}${rel//\%/%%}%f"
    return 1
  }

  local stage_root
  case $root_kind in
    HOME) stage_root=$payload_root/home ;;
    ZDOTDIR) stage_root=$payload_root/zdotdir ;;
    *)
      print -Pru2 -- "%F{3}z4m%f: %Bpack%b: invalid root kind: %F{1}${root_kind//\%/%%}%f"
      return 1
      ;;
  esac

  local stage=$stage_root/$rel
  zf_mkdir -p -- "${stage:h}" || return
  zf_rm -rf -- "$stage" || return
  if [[ -n $exclude_blob ]]; then
    -z4m-copy-path-with-excludes "$src" "$stage" follow "$exclude_blob" || return
  else
    command cp -RLp -- "$src" "$stage" || return
  fi
  [[ -e $stage || -L $stage ]] || return 0
  print -r -- "${root_kind}"$'\t'"${rel}" >>"$manifest" || return
}

{
  local payload_root=$tmpdir/payload
  local manifest=$tmpdir/install.manifest

  zf_mkdir -p -- "$payload_root/home" "$payload_root/zdotdir" || return
  : >"$manifest" || return

  local rel
  for rel in .zshenv .zprofile .zshrc .zlogin .zlogout; do
    -z4m-pack-stage-path "$local_zdotdir/$rel" ZDOTDIR "$rel" "$payload_root" "$manifest" || return
  done
  local p10k_file
  for p10k_file in $local_zdotdir/.p10k{,-ascii}{,-8color}.zsh(N); do
    -z4m-pack-stage-path "$p10k_file" ZDOTDIR "${p10k_file#$local_zdotdir/}" "$payload_root" "$manifest" || return
  done

  local extra
  local -a parsed_local parsed_root parsed_rel parsed_exclude
  for extra in $extra_files; do
    parsed_local=()
    parsed_root=()
    parsed_rel=()
    parsed_exclude=()
    -z4m-pack-parse-copy-spec "$extra" "$local_zdotdir" parsed_local parsed_root parsed_rel parsed_exclude || return

    local -i idx
    for idx in {1..$#parsed_local}; do
      -z4m-pack-stage-path "$parsed_local[idx]" "$parsed_root[idx]" "$parsed_rel[idx]" "$payload_root" "$manifest" "$parsed_exclude[idx]" || return
    done
  done

  # Create tarball of z4m installation.
  local z4m_tar=$tmpdir/z4m.tar.gz
  {
    local -a z4m_entries=()
    [[ -f $Z4M/z4m.zsh ]] && z4m_entries+=(z4m.zsh)
    local -a z4m_dirs=(
      $Z4M/zsh4monkey
      $Z4M/fzf
      $Z4M/powerlevel10k
      $Z4M/zsh-users
      $Z4M/terminfo
    )
    local d
    for d in $z4m_dirs; do
      [[ -d $d ]] && z4m_entries+=(${d#$Z4M/})
    done
    if (( $#z4m_entries )); then
      COPYFILE_DISABLE=1 command tar -C "$Z4M" -czf "$z4m_tar" -- $z4m_entries
    fi
  } 2>/dev/null

  {
    local -a archive_entries=(install.manifest payload)
    [[ -f $z4m_tar ]] && archive_entries+=(z4m.tar.gz)
    cat <<'HEADER'
#!/bin/sh
#
# z4m Offline Installation Package
# Generated by: z4m pack
#
# Usage: sh z4m-offline-install.sh [ZDOTDIR]
#
# This script installs z4m and its dependencies on a machine without
# internet access. Run it on the target machine.
#

set -e

ZDOTDIR="${1:-$HOME}"
Z4M="${Z4M:-${XDG_CACHE_HOME:-$HOME/.cache}/zsh4monkey}"

echo "Installing z4m to: $Z4M"
echo "ZDOTDIR: $ZDOTDIR"

mkdir -p "$HOME"
mkdir -p "$Z4M"
mkdir -p "$ZDOTDIR"

SCRIPT_PATH="$0"
MARKER='___Z4M_DATA_MARKER___'

DATA_OFFSET=$(grep -n "^$MARKER\$" "$SCRIPT_PATH" | tail -1 | cut -d: -f1)
if [ -z "$DATA_OFFSET" ]; then
  echo "Error: Data marker not found" >&2
  exit 1
fi
DATA_OFFSET=$((DATA_OFFSET + 1))

TMPDIR=$(mktemp -d)
trap "rm -rf '$TMPDIR'" EXIT

b64decode() {
  base64 -d 2>/dev/null || base64 -D 2>/dev/null
}

tail -n +$DATA_OFFSET "$SCRIPT_PATH" | b64decode | tar -xzmf - -C "$TMPDIR"

if [ -f "$TMPDIR/z4m.tar.gz" ]; then
  tar -xzmf "$TMPDIR/z4m.tar.gz" -C "$Z4M"
  echo "Installed z4m core"
fi

MANIFEST="$TMPDIR/install.manifest"
TAB="$(printf '\t')"
if [ -f "$MANIFEST" ]; then
  while IFS="$TAB" read -r root rel; do
    [ -n "$root" ] || continue
    case "$root" in
      HOME)
        base="$HOME"
        stage_root="$TMPDIR/payload/home"
        ;;
      ZDOTDIR)
        base="$ZDOTDIR"
        stage_root="$TMPDIR/payload/zdotdir"
        ;;
      *)
        echo "Error: invalid manifest root: $root" >&2
        exit 1
        ;;
    esac

    src="$stage_root/$rel"
    dst="$base/$rel"
    dst_dir=${dst%/*}
    if [ "$dst_dir" = "$dst" ]; then
      dst_dir="$base"
    fi

    mkdir -p "$dst_dir"
    rm -rf "$dst"
    cp -Rp "$src" "$dst"
    echo "Installed $dst"
  done < "$MANIFEST"
fi

echo ""
echo "Installation complete!"
echo ""
echo "To use z4m, start a new zsh session:"
echo "  exec zsh"
echo ""

exit 0

___Z4M_DATA_MARKER___
HEADER

    {
      COPYFILE_DISABLE=1 command tar -C "$tmpdir" -czf - -- $archive_entries
    } | base64

  } >"$output" || return

  chmod +x "$output"

  print -Pr -- "%F{3}z4m%f: created %F{2}${output//\%/%%}%f ($(command du -h $output | cut -f1))"
  print -Pr -- ""
  print -Pr -- "To install on a remote machine without internet:"
  print -Pr -- "  1. Copy %B${output//\%/%%}%b to the target machine"
  print -Pr -- "  2. Run: %Bsh ${output//\%/%%}%b"

} always {
  builtin unfunction -z4m-pack-stage-path 2>/dev/null || true
  zf_rm -rf -- $tmpdir
}

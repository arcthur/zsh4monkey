#!/usr/bin/env zsh
#
# Check for CLI tools and suggest installation if missing
# Usage: -z4m-postinstall-cli-tool <tool-name> <github-repo>
#

emulate -L zsh -o typeset_silent -o pipe_fail -o extended_glob \
    -o prompt_percent -o no_prompt_subst -o no_prompt_bang -o no_bg_nice -o no_aliases

local tool=$1 repo=$2

if (( $+commands[$tool] )); then
  print -r -- "system" > "$Z4M_PACKAGE_DIR/.system-tool"
  print -Pru2 -- "%F{3}z4m%f: %B${tool}%b found at %F{2}${commands[$tool]}%f"
  return 0
fi

# Tool not found - suggest installation methods
print -Pru2 -- "%F{3}z4m%f: %B${tool}%b not found"
print -Pru2 -- ""

local uname_s=${$(uname -s 2>/dev/null):-unknown}
local -a suggestions=()

# Package/crate names often differ from the binary name and across managers,
# and some tools (fzf, carapace, tmux) are not Rust crates, so a blanket
# "cargo install <binary>" would just fail.
local -A brew_pkg=(rg ripgrep)
local -A apt_pkg=(rg ripgrep fd fd-find)
local -A dnf_pkg=(rg ripgrep fd fd-find)
local -A cargo_pkg=(rg ripgrep fd fd-find eza eza bat bat zoxide zoxide atuin atuin)

case $uname_s in
  Darwin)
    suggestions+=("brew install ${brew_pkg[$tool]:-$tool}")
    ;;
  Linux)
    (( $+commands[apt] )) && suggestions+=("sudo apt install ${apt_pkg[$tool]:-$tool}")
    (( $+commands[dnf] )) && suggestions+=("sudo dnf install ${dnf_pkg[$tool]:-$tool}")
    (( $+commands[pacman] )) && suggestions+=("sudo pacman -S ${tool}")
    ;;
esac

# Only suggest cargo for tools that are actually published crates.
[[ -n ${cargo_pkg[$tool]-} ]] && suggestions+=("cargo install ${cargo_pkg[$tool]}")
(( $+commands[mise] )) && suggestions+=("mise use -g $tool")

print -Pru2 -- "  Install with one of:"
local s
for s in $suggestions; do
  print -Pru2 -- "    %F{6}$s%f"
done
print -Pru2 -- ""

return 0
